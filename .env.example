# ============================================
# Tickit Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================
# API Configuration (REQUIRED)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ============================================
# Google Sign-In (optional – enables "Sign in with Google" on login/signup)
# ============================================
# Create OAuth 2.0 Client ID (Web application) at https://console.cloud.google.com/apis/credentials
# Add authorized JavaScript origins: http://localhost:3000 and your production URL
# For redirect flow, use: https://accounts.google.com/o/oauth2/v2/auth?client_id=...&redirect_uri=...&response_type=code&scope=email%20profile
NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789012-abcde12345fghijklmno.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ============================================
# Facebook Login (optional – enables "Sign in with Facebook")
# ============================================
# NEXT_PUBLIC_FACEBOOK_APP_ID=
